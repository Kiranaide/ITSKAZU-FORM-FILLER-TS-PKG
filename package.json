{
  "name": "itskazu-form-filler",
  "version": "0.1.2",
  "description": "Zero-dependency form recording and replay package for browser apps.",
  "author": "ItsKazu",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "itskazu-form-filler": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  }
}
