{
  "name": "kazu-fira",
  "version": "1.1.0",
  "description": "Framework-agnostic form recorder and replayer. Zero runtime dependencies.",
  "author": "ItsKazu",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "kazu-fira": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@changesets/cli": "^2.29.7",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5",
    "ws": "^8.20.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  }
}
