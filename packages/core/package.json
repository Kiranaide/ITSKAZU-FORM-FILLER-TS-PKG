{
  "name": "kazu-fira",
  "version": "3.0.0",
  "description": "Framework-agnostic form recorder and replayer.",
  "author": "ItsKazu",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.2"
  }
}
